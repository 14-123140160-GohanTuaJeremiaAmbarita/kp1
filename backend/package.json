{
  "name": "smart-it-assistant-backend",
  "version": "1.0.0",
  "description": "AI Helpdesk Backend menggunakan SQL Server dan Gemini",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "gemini": "ts-node src/testGemini.ts",
    "models": "ts-node src/testModels.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rmdir /s /q dist"
  },
  "keywords": [
    "express",
    "typescript",
    "sqlserver",
    "gemini",
    "ai",
    "helpdesk"
  ],
  "author": "Gohan",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^2.10.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "fast-levenshtein": "^3.0.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "mssql": "^12.6.0",
    "pdfkit": "^0.19.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/mssql": "^12.3.0",
    "@types/node": "^26.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
